{
  "developer": {
    "enableDeveloperConsole": false,
    "enableYoutubeDeveloperConsole": false
  },
  "window": {
    "width": 480,
    "height": 220,
    "minWidth": 480,
    "minHeight": 220,
    "useAcrylic": false
  },
  "discordRichPresence": {
    "enabledByDefault": true,
    "applicationId": "your_app_id_from_dev_portal",
    "largeImageKeyListening": "leaf_listening",
    "presenceUpdateIntervalMs": 5000,
    "watchButtonText": "watch 🍃",
    "listenButtonText": "listen 🍃",
    "customButtonText": "leaftube 🌿 code",
    "customButtonUrl": "https://github.com/mntbliss/leaftube-"
  },
  "youtubeMusic": {
    "url": "https://music.youtube.com",
    "useVideosInsteadOfPicture": true,
    "pollIntervalMs": 800
  },
  "uiText": {
    "appTitle": "leaftube",
    "subtitle": "tea-leaf calm for your YouTube Music",
    "searchPlaceholder": "Search on YouTube Music",
    "toggleDiscordLabel": "Discord Rich Presence",
    "expandLabel": "Open player",
    "collapseLabel": "Close player"
  }
}
